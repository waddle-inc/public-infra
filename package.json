{
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "lint": "docker compose --env-file .env.example config > /dev/null && shellcheck deploy.sh .claude/hooks/setup-web.sh",
    "format": "prettier --write \"**/*.md\" \"**/*.yml\" \"**/*.yaml\" \"**/*.json\"",
    "toc": "find docs -name '*.md' -exec grep -ql '<!-- toc -->' {} \\; -exec markdown-toc -i --bullets=- {} \\;"
  },
  "devDependencies": {
    "markdown-toc": "^1.2.0",
    "prettier": "^3.8.3",
    "shellcheck": "^4.1.0"
  }
}
